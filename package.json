{
  "name": "imageforge",
  "version": "1.0.0",
  "description": "Image Processing Tool — Binaire Assessment",
  "main": "electron/main.js",
  "homepage": "./",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "build:win": "npm run build && node obfuscate.js && electron-builder --win && node electron/fuse.js",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "build": {
    "appId": "com.binaire.imageforge",
    "productName": "ImageForge",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "assets/**/*",
      "index.html"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@adobe/react-spectrum": "^3.34.0",
    "@react-spectrum/provider": "^3.9.6",
    "@spectrum-icons/ui": "^3.6.6",
    "@spectrum-icons/workflow": "^4.2.6",
    "@tensorflow-models/body-pix": "^2.2.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^4.1.0",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  }
}
